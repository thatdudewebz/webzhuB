-- Dynamically load Turrets
local TurretsDB = {}
local TurretNamesList = {}
pcall(function() 
    TurretsDB = require(ReplicatedStorage.Databases.Turrets) 
    for turretName, _ in pairs(TurretsDB) do table.insert(TurretNamesList, turretName) end
    table.sort(TurretNamesList)
end)
if #TurretNamesList == 0 then TurretNamesList = {"Pea Shooter", "Revolver", "Gatling Gun", "Plasma Rifle"} end

local function GetBaseDPS(turretName)
    local data = TurretsDB[turretName]
    if data and data.Damage then return data.Damage * (data.FireRate or 1) end
    return 0
end

