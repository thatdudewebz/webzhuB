-- 4. SMART AUTO-SHOP (Dynamic Restock Timer)
task.spawn(function()
    while true do
        if getgenv().Config.AutoBuyShop then
            FirePrompt("Open Shop")
            task.wait(1) 
            
            local sleepTime = 5 
            
            for _, gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
                if gui:IsA("TextLabel") and table.find(getgenv().Config.ShopItems, gui.Text) then
                    local parent = gui.Parent
                    if parent then
                        local buyBtn = parent:FindFirstChild("Buy")
                        if buyBtn and buyBtn:IsA("ImageButton") then VirtualClick(buyBtn) end
                    end
                end
                
                if gui:IsA("TextLabel") and gui.Text:match("RESTOCK IN (%d+):(%d+)") then
                    local m, s = gui.Text:match("RESTOCK IN (%d+):(%d+)")
                    if m and s then
                        local totalSeconds = (tonumber(m) * 60) + tonumber(s)
                        if totalSeconds > 0 then
                            sleepTime = totalSeconds + 2 
                        end
                    end
                end
            end
            
            task.wait(sleepTime) 
        else
            task.wait(5) 
        end
    end
end)

