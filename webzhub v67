local function FormatNumber(n)
    if not n then return "0" end
    if type(n) ~= "number" then return tostring(n) end
    if n >= 1e18 then return string.format("%.2fQt", n / 1e18) end
    if n >= 1e15 then return string.format("%.2fQd", n / 1e15) end
    if n >= 1e12 then return string.format("%.2fT", n / 1e12) end
    if n >= 1e9 then return string.format("%.2fB", n / 1e9) end
    if n >= 1e6 then return string.format("%.2fM", n / 1e6) end
    if n >= 1e3 then return string.format("%.2fK", n / 1e3) end
    return tostring(math.floor(n))
end

local function GetRealDPS(obj)
    if not obj then return 0 end
    local directDPS = obj:GetAttribute("DPS") or obj:GetAttribute("dps") or obj:GetAttribute("BaseDPS")
    if not directDPS then
        local val = obj:FindFirstChild("DPS") or obj:FindFirstChild("dps") or obj:FindFirstChild("BaseDPS")
        if val and (val:IsA("NumberValue") or val:IsA("IntValue")) then directDPS = val.Value end
    end
    if directDPS and type(directDPS) == "number" then return directDPS end
    
    local actualDmg = obj:GetAttribute("Damage") or obj:GetAttribute("damage")
    if not actualDmg then
        local val = obj:FindFirstChild("Damage") or obj:FindFirstChild("damage")
        if val and (val:IsA("NumberValue") or val:IsA("IntValue")) then actualDmg = val.Value end
    end
    
    local actualRate = obj:GetAttribute("FireRate") or obj:GetAttribute("Firerate") or obj:GetAttribute("firerate")
    if not actualRate then
        local val = obj:FindFirstChild("FireRate") or obj:FindFirstChild("Firerate") or obj:FindFirstChild("firerate")
        if val and (val:IsA("NumberValue") or val:IsA("IntValue")) then actualRate = val.Value end
    end
    
    if type(actualDmg) == "number" and type(actualRate) == "number" then return actualDmg * actualRate end
    local turretName = typeof(obj) == "string" and obj or obj.Name
    if TurretsDB[turretName] and TurretsDB[turretName].Damage then return TurretsDB[turretName].Damage * (TurretsDB[turretName].FireRate or 1) end
    return 0
end

local function GetBaseDPS(turretName)
    local data = TurretsDB[turretName]
    if data and data.Damage then return data.Damage * (data.FireRate or 1) end
    return 0
end

local function GetTotalPower(obj)
    return GetRealDPS(obj)
end

