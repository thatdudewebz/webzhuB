end

local function SaveSettings()
    pcall(function() if writefile then writefile(SaveFileName, HttpService:JSONEncode(getgenv().Config)) end end)
end

local function VirtualClick(button)
    if not button then return end
    pcall(function() firesignal(button.MouseButton1Click) end)
    pcall(function() firesignal(button.MouseButton1Down) end)
    pcall(function() firesignal(button.Activated) end)
    pcall(function() for _, conn in ipairs(getconnections(button.MouseButton1Click)) do conn:Fire() end end)
end

local function FirePrompt(actionText)
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.ActionText == actionText then
            pcall(function() fireproximityprompt(obj, 1, true) end)
            pcall(function() fireproximityprompt(obj) end)
        end
    end
end

-- ==========================================
-- GPS PLOT FINDER
-- ==========================================
local function GetMyPlot()
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end

    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local myPos = LocalPlayer.Character.HumanoidRootPart.Position
        local closestPlot, closestDist = nil, 150 
        
        for _, plot in ipairs(plotsFolder:GetChildren()) do
            if plot:IsA("Model") and plot.PrimaryPart then
                local dist = (plot.PrimaryPart.Position - myPos).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closestPlot = plot
                end
            end
        end
        if closestPlot then return closestPlot end
    end
    return nil
end

