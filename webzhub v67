local function SendStandaloneMessage(title, description, color, contentText)
    local url = getgenv().Config.WebhookURL
    if not url or url == "" or not getgenv().Config.UseWebhook then return end

    local embed = {
        ["title"] = title, ["description"] = description, ["color"] = color or 7506394,
        ["timestamp"] = DateTime.now():ToIsoDate(), ["footer"] = {["text"] = "Webz Hub v67.⁶⁹"}
    }
    
    local payloadData = {["username"] = "Webz Hub Logger", ["embeds"] = {embed}}
    if contentText then payloadData["content"] = contentText end
    local payload = HttpService:JSONEncode(payloadData)

    local requestFunc = syn and syn.request or http and http.request or http_request or fluxus and fluxus.request or request
    if requestFunc then task.spawn(function() pcall(function() requestFunc({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end) end) end
end

local function LogAction(msg, pingType)
    if not getgenv().Config.UseWebhook or getgenv().Config.WebhookURL == "" then return end
    
    if getgenv().LastLogMsg == msg then return end
    getgenv().LastLogMsg = msg

    local timeStr = "<t:" .. math.floor(os.time()) .. ":T>"
    table.insert(getgenv().RecentLogs, 1, timeStr .. " - " .. msg)
    if #getgenv().RecentLogs > 7 then table.remove(getgenv().RecentLogs, 8) end

    if pingType and getgenv().Config.PingOwner and getgenv().Config.DiscordID ~= "" then
        local url = getgenv().Config.WebhookURL
        local contentMsg = ""
        if pingType == "Critical" then contentMsg = "🚨 <@" .. getgenv().Config.DiscordID .. "> **CRITICAL ALERT:** " .. msg
        elseif pingType == "Turret" then contentMsg = "🔫 <@" .. getgenv().Config.DiscordID .. "> **Turret Bought:** " .. msg
        elseif pingType == "Item" then contentMsg = "🛒 <@" .. getgenv().Config.DiscordID .. "> **Item Bought:** " .. msg
        elseif pingType == "Event" then contentMsg = "📢 <@" .. getgenv().Config.DiscordID .. "> **Event:** " .. msg end
        
        if contentMsg ~= "" then
            local requestFunc = syn and syn.request or http and http.request or http_request or fluxus and fluxus.request or request
            if requestFunc then pcall(function() requestFunc({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode({["content"] = contentMsg, ["username"] = "Webz Hub Alerts"})}) end) end
        end
    end
end

