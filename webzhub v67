-- PLAYER UPGRADES HELPER
-- ==========================================
local function ProcessPlayerUpgrade(upgradeName, configCapKey)
    local cap = getgenv().Config[configCapKey] or 200
    local currentLevel = -1 
    local buyBtn = nil
    
    local searchName1 = upgradeName:lower()
    local searchName2 = upgradeName:lower():gsub(" ", "")
    
    for _, gui in ipairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if gui:IsA("TextLabel") then
            local txt = gui.Text:lower()
            if txt == searchName1 or txt:match(searchName2) or (searchName1 == "turret spin luck" and txt:match("turret") and txt:match("luck")) then
                local parent = gui.Parent
                if parent then
                    for _, desc in ipairs(parent:GetDescendants()) do
                        if desc:IsA("TextLabel") then
                            local lvl = desc.Text:match("Lvl%.?%s*(%d+)") or desc.Text:match("Level%s*:?%s*(%d+)") or desc.Text:match("^(%d+)%s*/")
                            if lvl then currentLevel = tonumber(lvl) end
                        end
                        if desc:IsA("ImageButton") or desc:IsA("TextButton") then
                            if desc.Name:lower():match("buy") or desc.Name:lower():match("upgrade") or desc:FindFirstChild("Price") then
                                buyBtn = desc
                            end
                        end
                    end
                    if not buyBtn and (parent:IsA("ImageButton") or parent:IsA("TextButton")) then buyBtn = parent end
                end
            end
        end
    end
    
    if currentLevel == -1 then
        for _, obj in ipairs(LocalPlayer:GetDescendants()) do
            if (obj:IsA("IntValue") or obj:IsA("NumberValue")) and obj.Name:lower():match(searchName2) then
                currentLevel = obj.Value
            end
        end
    end
    
    if currentLevel == -1 then return end
    
    if currentLevel < cap then
        if buyBtn then VirtualClick(buyBtn) end
        local upgradesRemote = ReplicatedStorage:FindFirstChild("Events") 
            and ReplicatedStorage.Events:FindFirstChild("Global") 
            and ReplicatedStorage.Events.Global:FindFirstChild("Upgrades") 
            and ReplicatedStorage.Events.Global.Upgrades:FindFirstChild("Buy")
            
        if upgradesRemote then
            pcall(function() upgradesRemote:FireServer(upgradeName) end)
            pcall(function() upgradesRemote:FireServer(searchName2) end)
            if searchName1 == "turret spin luck" then
                pcall(function() upgradesRemote:FireServer("TurretLuck") end)
                pcall(function() upgradesRemote:FireServer("SpinLuck") end)
            end
        end
    end
end

