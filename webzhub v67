local EventItemPrices = {
    ["Acid Oil"] = 150, ["Shiny Oil"] = 300, ["Blizzard Oil"] = 750, ["Galaxy Oil"] = 1000,
    ["OverClock"] = 75, ["SuperClock"] = 200, ["HyperClock"] = 400,
    ["1m Time skip"] = 25, ["2m Time skip"] = 40, ["5m Time skip"] = 100,
    ["1 Blizzard Crate"] = 900, ["3 Blizzard Crates"] = 2100, ["10 Blizzard Crates"] = 5400
}

local function ParseValue(str)
    if not str then return 0 end
    str = string.lower(string.gsub(str, "[,%$%s]", ""))
    local num = tonumber(str)
    if num then return num end
    local val, suffix = string.match(str, "^([%d%.]+)([kmbt]+)$")
    if val then
        val = tonumber(val)
        if suffix == "k" then return math.floor(val * 1000)
        elseif suffix == "m" then return math.floor(val * 1000000)
        elseif suffix == "b" then return math.floor(val * 1000000000)
        elseif suffix == "t" then return math.floor(val * 1000000000000) end
    end
    return 0
end

