-- == DISCORD WEBHOOK ENGINE (WITH CUSTOM PINGS) ==
local WebhookCooldowns = {}

local function SendWebhook(throttleKey, cooldownSecs, title, description, color, forcePing)
    local url = getgenv().Config.WebhookURL
    if not url or url == "" or not getgenv().Config.UseWebhook then return end

    if throttleKey and cooldownSecs then
        if WebhookCooldowns[throttleKey] and (tick() - WebhookCooldowns[throttleKey]) < cooldownSecs then
            return 
        end
        WebhookCooldowns[throttleKey] = tick()
    end

    local embed = {
        ["title"] = title,
        ["description"] = description,
        ["color"] = color or 7506394,
        ["timestamp"] = DateTime.now():ToIsoDate(),
        ["footer"] = {["text"] = "Webz Hub v67 | Zombie Farm Automater"}
    }

    local contentMsg = nil
    if forcePing and getgenv().Config.PingOwner and getgenv().Config.DiscordID ~= "" then
        contentMsg = "<@" .. getgenv().Config.DiscordID .. "> ⚠️ CRITICAL ALERT!"
    end

    local payloadData = {
        ["username"] = "Webz Hub Logger",
        ["embeds"] = {embed}
    }
    if contentMsg then payloadData["content"] = contentMsg end

    local payload = HttpService:JSONEncode(payloadData)

    local requestFunc = syn and syn.request or http and http.request or http_request or fluxus and fluxus.request or request
    if requestFunc then
        task.spawn(function()
            pcall(function() requestFunc({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload}) end)
        end)
    end
end

-- == VIRTUAL ENGINE ==
local function VirtualClick(button)
    if not button then return end
    pcall(function() firesignal(button.MouseButton1Click) end)
    pcall(function() firesignal(button.MouseButton1Down) end)
    pcall(function() firesignal(button.Activated) end)
    pcall(function() for _, conn in ipairs(getconnections(button.MouseButton1Click)) do conn:Fire() end end)
end

local function FirePrompt(actionText)
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.ActionText == actionText then
            pcall(function() fireproximityprompt(obj, 1, true) end)
            pcall(function() fireproximityprompt(obj) end)
        end
    end
end

local function GetMyPlot()
    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end

    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local myPos = LocalPlayer.Character.HumanoidRootPart.Position
        local closestPlot, closestDist = nil, 150 
        for _, plot in ipairs(plotsFolder:GetChildren()) do
            if plot:IsA("Model") and plot.PrimaryPart then
                local dist = (plot.PrimaryPart.Position - myPos).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closestPlot = plot
                end
            end
        end
        if closestPlot then return closestPlot end
    end
    return nil
end

