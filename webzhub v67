-- Dynamically load Turrets
local TurretsDB = {}
local TurretNamesList = {}
pcall(function() 
    TurretsDB = require(ReplicatedStorage.Databases.Turrets) 
    for turretName, _ in pairs(TurretsDB) do table.insert(TurretNamesList, turretName) end
    table.sort(TurretNamesList)
