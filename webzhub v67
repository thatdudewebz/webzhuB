-- 3. SMART AUTO-SWAP LOOP
task.spawn(function()
    while true do
        local waitTime = getgenv().Config.SwapInterval or 10
        task.wait(waitTime)
        
        if getgenv().Config.AutoSwap then
            local myPlot = GetMyPlot()
            if myPlot and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                
                local bestTool, bestDPS = nil, -1
                local allTools = LocalPlayer.Backpack:GetChildren()
                for _, t in ipairs(LocalPlayer.Character:GetChildren()) do table.insert(allTools, t) end
                
                for _, tool in ipairs(allTools) do
                    if tool:IsA("Tool") and TurretsDB[tool.Name] then
                        local baseDPS = GetBaseDPS(tool.Name)
                        if baseDPS > bestDPS then
                            bestDPS = baseDPS
                            bestTool = tool
                        end
                    end
                end
                
                if bestTool then
                    LocalPlayer.Character.Humanoid:EquipTool(bestTool)
                    task.wait(0.5) 
                    
                    local emptySlabPrompt = nil
                    for _, prompt in ipairs(myPlot:GetDescendants()) do
                        if prompt:IsA("ProximityPrompt") then
                            local act = prompt.ActionText:lower()
                            if act:match("place") or act:match("equip") or act:match("build") then
                                emptySlabPrompt = prompt
                                break
                            end
                        end
                    end
                    
                    if emptySlabPrompt then
                        pcall(function() fireproximityprompt(emptySlabPrompt, 1, true) end)
                        pcall(function() fireproximityprompt(emptySlabPrompt) end)
                    else
                        local weakestModel, weakestDPS = nil, math.huge
                        local turretsFolder = myPlot:FindFirstChild("Turrets")
                        
                        if turretsFolder then
                            for _, obj in ipairs(turretsFolder:GetChildren()) do
                                if obj:IsA("Model") and TurretsDB[obj.Name] then
                                    local baseDPS = GetBaseDPS(obj.Name)
                                    if baseDPS < weakestDPS then
                                        weakestDPS = baseDPS
                                        weakestModel = obj
                                    end
                                end
                            end
                        end
                        
                        -- FAILPROOF CHECK: Only swaps if best is strictly greater!
                        if weakestModel and bestDPS > weakestDPS then
                            local turretId = weakestModel:GetAttribute("TurretId")
                            local gridCell = weakestModel:GetAttribute("GridCell")
                            
                            pcall(function() CoreEvents.TurretPickup:FireServer(weakestModel) end)
                            if turretId then pcall(function() CoreEvents.TurretPickup:FireServer(turretId) end) end
                            if gridCell then pcall(function() CoreEvents.TurretPickup:FireServer(gridCell) end) end
                        end
                    end
                end
            end
        end
    end
end)

