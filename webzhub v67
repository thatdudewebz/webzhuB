local function GetBaseDPS(turretName)
    local data = TurretsDB[turretName]
    if data and data.Damage then return data.Damage * (data.FireRate or 1) end
    return 0
end

local function GetTotalPower(obj)
    local level = obj:GetAttribute("TurretLevel") or obj:GetAttribute("Level") or 1
    if type(level) ~= "number" then level = tonumber(level) or 1 end
    local power = level
    local oil = obj:GetAttribute("Oil")
    if oil and oil ~= "" and oil ~= "None" then power = power + 1000 end
    local clock = obj:GetAttribute("Clock")
    if clock and clock ~= "" and clock ~= "None" then power = power + 500 end
    return power
end

